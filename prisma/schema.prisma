// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


/// ================= ENUM =================
enum Role {
  user
  admin
}

enum Language {
  cpp
  java
  python
  javascript
  typescript
  go
  rust
}

enum SubmissionStatus {
  pending
  running
  accepted
  wrong_answer
  time_limit_exceeded
  memory_limit_exceeded
  runtime_error
  compile_error
}

/// ================= USERS =================
model User {
  id            String   @id @default(uuid()) @db.Char(36)
  username      String   @unique @db.VarChar(50)
  email         String   @unique @db.VarChar(255)
  passwordHash  String  @map("password_hash") @db.VarChar(255)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  birthday      DateTime? @map("birthday") @db.Date
  role          Role     @default(user)
  solvedCount   Int      @default(0) @map("solved_count")
  streakDays    Int      @default(0) @map("streak_days")
  lastActive    DateTime? @map("last_active") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  oauthAccounts OAuthAccount[]
  problems      Problem[] @relation("ProblemCreator")
  submissions   Submission[]
  userProblems  UserProblemStatus[]
  refreshTokens RefreshToken[]
  
  announcements Announcement[]
  discussions   Discussion[]
  comments      Comment[]
  commentInteractions  UserCommentInteraction[]
  interactions  UserDiscussionInteraction[]

  @@map("users")
}

/// ================= OAUTH =================
model OAuthAccount {
  id           String @id @default(uuid()) @db.Char(36)
  userId       String @map("user_id") @db.Char(36)
  provider     String @db.VarChar(32)
  providerUid  String @map("provider_uid") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@map("oauth_accounts")
}

/// ================= TAGS =================
model Tag {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  problemTags ProblemTag[]

  @@map("tags")
}

/// ================= PROBLEMS =================
model Problem {
  id              String   @id @default(uuid()) @db.Char(36)
  title           String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  description     String   @db.LongText
  difficulty      Int      @default(0) @map("difficulty")
  isActive        Boolean  @default(true) @map("is_active")
  acceptanceRate  Decimal  @default(0.00) @map("acceptance_rate") @db.Decimal(5,2)
  totalAccepted   Int      @default(0) @map("total_accepted")
  totalSubmitted  Int      @default(0) @map("total_submitted")
  createdBy       String?  @map("created_by") @db.Char(36)
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  creator       User?               @relation("ProblemCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  testCases     TestCase[]
  codeTemplates CodeTemplate[]
  submissions   Submission[]
  problemTags   ProblemTag[]
  userProblems  UserProblemStatus[]
  examples      ProblemExample[]
  constraints   ProblemConstraint[]

  discussions   Discussion[]
  
  @@map("problems")
}

/// ================= PROBLEM_TAGS =================
model ProblemTag {
  problemId String @map("problem_id") @db.Char(36)
  tagId     String @map("tag_id") @db.Char(36)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([problemId, tagId])
  @@map("problem_tags")
}

/// ================= TEST_CASES =================
model TestCase {
  id             String   @id @default(uuid()) @db.Char(36)
  problemId      String   @map("problem_id") @db.Char(36)
  input          String   @db.LongText
  expectedOutput String   @map("expected_output") @db.LongText
  isHidden       Boolean  @default(false) @map("is_hidden")
  orderIndex     Int      @default(0) @map("order_index")
  createdAt      DateTime @default(now()) @map("created_at")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("test_cases")
}

/// ================= CODE_TEMPLATES =================
model CodeTemplate {
  id           String   @id @default(uuid()) @db.Char(36)
  problemId    String   @map("problem_id") @db.Char(36)
  language     Language
  starterCode  String   @map("starter_code") @db.LongText
  solutionCode String?  @map("solution_code") @db.LongText
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, language])
  @@map("code_templates")
}

/// ================= SUBMISSIONS =================
model Submission {
  id           String           @id @default(uuid()) @db.Char(36)
  userId       String           @map("user_id") @db.Char(36)
  problemId    String           @map("problem_id") @db.Char(36)
  language     Language
  code         String           @db.LongText
  status       SubmissionStatus @default(pending)
  runtimeMs    Int?             @map("runtime_ms")
  memoryKb     Int?             @map("memory_kb")
  passedCases  Int              @default(0) @map("passed_cases")
  totalCases   Int              @default(0) @map("total_cases")
  errorMessage String?          @map("error_message") @db.Text
  submittedAt  DateTime         @default(now()) @map("submitted_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

/// ================= REFRESH_TOKENS =================
model RefreshToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.DateTime
  createdAt DateTime @default(now()) @map("created_at")
  revoked   Boolean  @default(false) @map("revoked")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

/// ================= USER_PROBLEM_STATUS =================
model UserProblemStatus {
  userId        String   @map("user_id") @db.Char(36)
  problemId     String   @map("problem_id") @db.Char(36)
  isSolved      Boolean  @default(false) @map("is_solved")
  bestRuntime   Int?     @map("best_runtime")
  bestMemory    Int?     @map("best_memory")
  firstSolved   DateTime? @map("first_solved")
  lastSubmitted DateTime @updatedAt @map("last_submitted")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([userId, problemId])
  @@map("user_problem_status")
}

/// ================= PROBLEM_EXAMPLES =================
model ProblemExample {
  id          String  @id @default(uuid()) @db.Char(36)
  problemId   String  @map("problem_id") @db.Char(36)
  input       String  @db.Text
  output      String  @db.Text
  explanation String? @db.Text
  orderIndex  Int     @default(0) @map("order_index")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("problem_examples")
}

/// ================= PROBLEM_CONSTRAINTS =================
model ProblemConstraint {
  id         String @id @default(uuid()) @db.Char(36)
  problemId  String @map("problem_id") @db.Char(36)
  content    String @db.Text
  orderIndex Int    @default(0) @map("order_index")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("problem_constraints")
}
/// ================= ANNOUNCEMENTS =================
model Announcement {
  id        String   @id @default(uuid()) @db.Char(36)
  title     String   @db.VarChar(255)
  content   String   @db.LongText
  isPinned  Boolean  @default(false) @map("is_pinned") // Thêm cờ ghim cho Admin
  authorId  String   @map("author_id") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

/// ================= DISCUSSIONS =================
model Discussion {
  id        String   @id @default(uuid()) @db.Char(36)
  problemId String?  @map("problem_id") @db.Char(36) // Null nếu là thảo luận chung
  userId    String   @map("user_id") @db.Char(36)
  title     String   @db.VarChar(255)
  content   String   @db.LongText
  tags      Json?    // Lưu mảng tags ví dụ: ["Python", "Algorithm"]
  isPinned  Boolean  @default(false) @map("is_pinned") 
  isDeleted Boolean  @default(false) @map("is_deleted")
  upvotes   Int      @default(0)
  views     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem?  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  comments  Comment[]
  
  interactions UserDiscussionInteraction[]

  @@map("discussions")
}

/// ================= COMMENTS =================
model Comment {
  id           String   @id @default(uuid()) @db.Char(36)
  discussionId String   @map("discussion_id") @db.Char(36)
  userId       String   @map("user_id") @db.Char(36)
  content      String   @db.Text
  isPinned     Boolean    @default(false) @map("is_pinned")
  parentId     String?  @map("parent_id") @db.Char(36) // Dùng để reply bình luận
  upvotes      Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  
  parent       Comment?   @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]  @relation("CommentToComment")
  interactions UserCommentInteraction[]

  @@map("comments")
}

/// ================= USER_DISCUSSION_INTERACTIONS =================
model UserDiscussionInteraction {
  userId       String   @map("user_id") @db.Char(36)
  discussionId String   @map("discussion_id") @db.Char(36)
  
  // 1 = Upvote (Like), -1 = Downvote (Dislike), 0 = Không làm gì
  voteType     Int      @default(0) @map("vote_type") 
  
  // Trạng thái lưu bài
  isSaved      Boolean  @default(false) @map("is_saved")
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  // Khóa chính kép: Chặn đứng tình trạng spam Like/Save
  @@id([userId, discussionId])
  @@map("user_discussion_interactions")
}

/// ================= USER_COMMENT_INTERACTIONS =================
model UserCommentInteraction {
  userId       String   @map("user_id") @db.Char(36)
  commentId    String   @map("comment_id") @db.Char(36)
  voteType     Int      @default(0) @map("vote_type") // 1: Like, -1: Dislike, 0: Hủy
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment      Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("user_comment_interactions")
}